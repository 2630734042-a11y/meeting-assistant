# ============================================
# 多Agent智能会议助手系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# ---------- LLM API ----------
# DeepSeek API (默认)
# 获取 Key: https://platform.deepseek.com/api_keys
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-chat

# 切换到其他 OpenAI 兼容服务示例:
# OpenAI:     LLM_BASE_URL=https://api.openai.com  LLM_MODEL=gpt-4o
# 通义千问:   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# 智谱:       LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MiniMax:    LLM_BASE_URL=https://api.minimax.chat/v1

# ---------- 语音转写 ----------
# HuggingFace 镜像（国内免VPN下载模型）
HF_ENDPOINT=https://hf-mirror.com
# Whisper 配置
WHISPER_MODEL_SIZE=large-v2
WHISPER_LANGUAGE=zh
WHISPER_DEVICE=cuda

# ---------- Jira 集成 ----------
JIRA_SERVER=https://your-company.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=MEET

# ---------- 飞书集成 ----------
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# ---------- 数据库 ----------
DATABASE_URL=postgresql://postgres:password@localhost:5432/meeting_assistant
REDIS_URL=redis://localhost:6379/0

# ---------- 服务配置 ----------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WEBSOCKET_PORT=8001
LOG_LEVEL=INFO
